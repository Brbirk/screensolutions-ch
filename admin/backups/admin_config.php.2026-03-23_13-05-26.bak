<?php
// === ADMIN KONFIGURATION ===
session_start();

// Basis-Verzeichnis der Website (eine Ebene höher)
define('BASE_DIR', realpath(__DIR__ . '/..'));

// Credentials-Datei
define('CREDENTIALS_FILE', __DIR__ . '/data/credentials.json');

// Admin E-Mail (für Passwort-Reset)
define('ADMIN_EMAIL', 'info@screensolutions.ch');

// Erlaubte Dateierweiterungen zum Bearbeiten
define('EDITABLE_EXTENSIONS', ['html', 'css', 'js', 'php', 'json', 'txt', 'xml', 'htaccess', 'md']);

// Erlaubte Bild-Erweiterungen
define('IMAGE_EXTENSIONS', ['jpg', 'jpeg', 'png', 'gif', 'svg', 'webp', 'ico']);

// Gesperrte Verzeichnisse (nicht anzeigen)
define('BLOCKED_DIRS', ['admin']);

// === CREDENTIALS FUNKTIONEN ===

// Credentials laden
function loadCredentials() {
    if (!file_exists(CREDENTIALS_FILE)) {
        // Erstmalige Einrichtung: Standard-Credentials erstellen
        $dataDir = dirname(CREDENTIALS_FILE);
        if (!is_dir($dataDir)) mkdir($dataDir, 0755, true);

        $default = [
            'username' => 'admin',
            'password' => password_hash('screensolutions2026', PASSWORD_DEFAULT),
            'email' => ADMIN_EMAIL,
            'created' => date('Y-m-d H:i:s'),
            'last_changed' => date('Y-m-d H:i:s')
        ];
        file_put_contents(CREDENTIALS_FILE, json_encode($default, JSON_PRETTY_PRINT));

        // .htaccess zum Schutz des data-Ordners
        file_put_contents($dataDir . '/.htaccess', "Deny from all\n");

        return $default;
    }
    return json_decode(file_get_contents(CREDENTIALS_FILE), true);
}

// Credentials speichern
function saveCredentials($data) {
    $dataDir = dirname(CREDENTIALS_FILE);
    if (!is_dir($dataDir)) mkdir($dataDir, 0755, true);
    return file_put_contents(CREDENTIALS_FILE, json_encode($data, JSON_PRETTY_PRINT));
}

// Login prüfen
function verifyLogin($username, $password) {
    $creds = loadCredentials();
    return ($username === $creds['username'] && password_verify($password, $creds['password']));
}

// Passwort ändern
function changePassword($newPassword) {
    $creds = loadCredentials();
    $creds['password'] = password_hash($newPassword, PASSWORD_DEFAULT);
    $creds['last_changed'] = date('Y-m-d H:i:s');
    return saveCredentials($creds);
}

// Reset-Token generieren
function generateResetToken() {
    $creds = loadCredentials();
    $token = bin2hex(random_bytes(32));
    $creds['reset_token'] = $token;
    $creds['reset_expires'] = date('Y-m-d H:i:s', strtotime('+1 hour'));
    saveCredentials($creds);
    return $token;
}

// Reset-Token prüfen
function verifyResetToken($token) {
    $creds = loadCredentials();
    if (!isset($creds['reset_token']) || !isset($creds['reset_expires'])) return false;
    if ($creds['reset_token'] !== $token) return false;
    if (strtotime($creds['reset_expires']) < time()) return false;
    return true;
}

// Reset-Token löschen
function clearResetToken() {
    $creds = loadCredentials();
    unset($creds['reset_token']);
    unset($creds['reset_expires']);
    saveCredentials($creds);
}

// === AUTH CHECK ===
function requireLogin() {
    if (!isset($_SESSION['admin_logged_in']) || $_SESSION['admin_logged_in'] !== true) {
        header('Location: login.php');
        exit;
    }
}

// === HILFS-FUNKTIONEN ===

function getExtension($filename) {
    return strtolower(pathinfo($filename, PATHINFO_EXTENSION));
}

function isEditable($filename) {
    return in_array(getExtension($filename), EDITABLE_EXTENSIONS);
}

function isImage($filename) {
    return in_array(getExtension($filename), IMAGE_EXTENSIONS);
}

function safePath($path) {
    $real = realpath(BASE_DIR . '/' . $path);
    if ($real === false || strpos($real, BASE_DIR) !== 0) {
        return false;
    }
    return $real;
}

function formatSize($bytes) {
    if ($bytes >= 1048576) return round($bytes / 1048576, 1) . ' MB';
    if ($bytes >= 1024) return round($bytes / 1024, 1) . ' KB';
    return $bytes . ' B';
}
