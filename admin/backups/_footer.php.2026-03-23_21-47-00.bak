<script src="/js/main.js?v=4"></script>
<script>
// Contact form XHR submission
document.addEventListener('DOMContentLoaded', function() {
    var form = document.getElementById('contactForm');
    if (!form) return;

    form.addEventListener('submit', function(e) {
        e.preventDefault();
        var btn = form.querySelector('button[type="submit"]');
        var origText = btn.textContent;
        btn.textContent = 'Wird gesendet...';
        btn.disabled = true;

        var formData = new FormData(form);
        // Add captcha answer from data attribute
        formData.set('captcha_answer', form.getAttribute('data-captcha-answer'));

        var xhr = new XMLHttpRequest();
        xhr.open('POST', '/send-mail.php', true);
        xhr.onload = function() {
            if (xhr.status === 200) {
                try {
                    var resp = JSON.parse(xhr.responseText);
                    if (resp.success) {
                        window.location.href = '/danke';
                    } else {
                        alert(resp.message || 'Fehler beim Senden.');
                        btn.textContent = origText;
                        btn.disabled = false;
                    }
                } catch(ex) {
                    alert('Fehler beim Senden. Bitte versuche es sp\u00e4ter.');
                    btn.textContent = origText;
                    btn.disabled = false;
                }
            } else {
                alert('Serverfehler. Bitte versuche es sp\u00e4ter.');
                btn.textContent = origText;
                btn.disabled = false;
            }
        };
        xhr.onerror = function() {
            alert('Netzwerkfehler. Bitte versuche es sp\u00e4ter.');
            btn.textContent = origText;
            btn.disabled = false;
        };
        xhr.send(formData);
    });

    // Radio button highlight on click
    var radios = form.querySelectorAll('input[name="angebot"]');
    radios.forEach(function(radio) {
        radio.addEventListener('change', function() {
            radios.forEach(function(r) {
                r.closest('label').style.borderColor = 'rgba(255,255,255,0.2)';
            });
            this.closest('label').style.borderColor = '#e74c3c';
        });
    });
});
</script>
<?php if (isset($extraScripts)) echo $extraScripts; ?>

