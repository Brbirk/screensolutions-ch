                        <tr>
                            <td><code><?= htmlspecialchars($page['file']) ?></code></td>
                            <td><?= htmlspecialchars(mb_substr($page['title'], 0, 40)) ?></td>
                            <td><?= date('d.m.Y H:i', $page['modified']) ?></td>
                            <td><a href="editor.php?file=<?= urlencode($page['file']) ?>" class="btn-edit">Bearbeiten</a></td>
