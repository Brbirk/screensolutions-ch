                            <th>DATEI</th>
                            <th>GRÖSSE</th>
                            <th>GEÄNDERT</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <?php
                        $codeFiles = array_merge(
                            array_map(fn($f) => ['path' => 'css/' . basename($f), 'file' => $f], $cssFiles),
                            array_map(fn($f) => ['path' => 'js/' . basename($f), 'file' => $f], $jsFiles),
                            array_map(fn($f) => ['path' => basename($f), 'file' => $f], $phpFiles)
                        );
                        usort($codeFiles, fn($a, $b) => filemtime($b['file']) - filemtime($a['file']));
                        foreach ($codeFiles as $cf):
                        ?>
                        <tr>
                            <td><code><?= htmlspecialchars($cf['path']) ?></code></td>
                            <td><?= formatSize(filesize($cf['file'])) ?></td>
                            <td><?= date('d.m.Y H:i', filemtime($cf['file'])) ?></td>
                            <td><a href="editor.php?file=<?= urlencode($cf['path']) ?>" class="btn-edit">Bearbeiten</a></td>
                        </tr>
                        <?php endforeach; ?>
                    </tbody>
                </table>
