<?php
require_once 'config.php';
requireLogin();

// Statistiken sammeln
$htmlFiles = glob(BASE_DIR . '/*.html');
$cssFiles  = glob(BASE_DIR . '/css/*.css');
$jsFiles   = glob(BASE_DIR . '/js/*.js');
$phpFiles  = glob(BASE_DIR . '/*.php');
$imgFiles  = glob(BASE_DIR . '/images/*.{jpg,jpeg,png,gif,svg,webp}', GLOB_BRACE);

$totalPages = count($htmlFiles);
$totalFiles = count($cssFiles) + count($jsFiles) + count($phpFiles);
$totalImages = count($imgFiles);

// Seiten mit Details
$pages = [];
foreach ($htmlFiles as $file) {
    $content = file_get_contents($file);
    preg_match('/<title>(.*?)<\/title>/i', $content, $matches);
    $title = $matches[1] ?? basename($file);
    $pages[] = [
        'file' => basename($file),
        'title' => $title,
        'modified' => filemtime($file),
        'size' => filesize($file)
    ];
}
usort($pages, function($a, $b) { return $b['modified'] - $a['modified']; });
?>
